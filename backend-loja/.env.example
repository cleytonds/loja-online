# Aplicacao
NODE_ENV=development
PORT=3001
FRONT_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false

# Banco MySQL/MariaDB
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=

# Autenticacao
JWT_SECRET=

# E-mail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Mercado Pago
MP_ENVIRONMENT=sandbox
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_COLLECTOR_ID=
MP_MAX_INSTALLMENTS=12

# Pedidos: habilite em apenas uma instancia sem lock distribuido.
ENABLE_ORDER_SCHEDULER=false

# Arquivos: em producao deve apontar para disco persistente.
UPLOAD_DIR=

# WhatsApp
WHATSAPP_NUMERO=
